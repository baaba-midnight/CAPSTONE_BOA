@startuml Adaptive AI Coding Assistant
hide circle
skinparam linetype ortho

entity "users" as users {
  +user_id : UUID <<PK>>
  --
  name : text
  email : text <<UNIQUE>>
  role : student | instructor | admin
  password_hash : text
  created_at : timestamptz
}

entity "assignments" as assignments {
  +assignment_id : UUID <<PK>>
  --
  title : text
  description : text
  created_at : timestamptz
  due_date : timestamptz
  created_by : UUID <<FK>>
}

entity "assignment_students" as assignment_students {
  +assignment_id : UUID <<PK, FK>>
  +student_id : UUID <<PK, FK>>
}

entity "chat_memory" as chat_memory {
  +chat_id : UUID <<PK>>
  --
  sender_type : student | instructor | system
  message_text : text
  created_at : timestamptz
  assignment_id : UUID <<FK>>
  user_id : UUID <<FK>>
}

entity "student_reflections" as student_reflections {
  +id : UUID <<PK>>
  --
  reflection_text : text
  confidence_rating : int (1–5)
  difficulty_rating : int (1–5)
  created_at : timestamptz
  student_id : UUID <<FK>>
  chat_id : UUID <<FK>>
  assignment_id : UUID <<FK>>
}

entity "reflection_analysis" as reflection_analysis {
  +id : UUID <<PK>>
  --
  confidence_score : int (1–5)
  understanding_score : int (1–5)
  difficulty_score : int (1–5)
  analysis_explanation : text
  analyzed_at : timestamptz
  reflection_id : UUID <<FK>>
}

entity "student_performance_metrics" as student_metrics {
  +student_id : UUID <<PK, FK>>
  --
  accuracy : real (0–1)
  hint_count : int
  struggles : int
  tasks_completed : int
  time_spent : real
  confidence_level : derived
  current_difficulty : int (1–5)
  support_level : int (1–3)
  last_updated : timestamptz
}

entity "student_state_changes" as state_changes {
  +id : UUID <<PK>>
  --
  change_type : text
  old_values : jsonb
  new_values : jsonb
  triggered_by : text
  created_at : timestamptz
  student_id : UUID <<FK>>
}

' --------------------
' Relationships
' --------------------

users ||--o{ assignments : creates
users ||--o{ assignment_students : enrolled_as
assignments ||--o{ assignment_students : has

assignments ||--o{ chat_memory : contextualizes
users ||--o{ chat_memory : sends

users ||--o{ student_reflections : writes
assignments ||--o{ student_reflections : relates_to
chat_memory ||--o{ student_reflections : based_on

student_reflections ||--|| reflection_analysis : analyzed_by

users ||--|| student_metrics : has
users ||--o{ state_changes : triggers

@enduml
